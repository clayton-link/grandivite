# ── Supabase ──────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Google Maps ──────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New) and Maps JavaScript API
# Restrict key to your domain for security
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ── Anthropic (for AI features) ─────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Resend (for email delivery) ──────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=your-resend-api-key

# ── Cron security ────────────────────────────────────────────
# Set a random secret to protect the /api/send-nudge endpoint
CRON_SECRET=your-random-secret-here

# ── Shared Calendar Feed ─────────────────────────────────────
# Families subscribe to: https://your-domain.com/api/calendar?token=YOUR_TOKEN
# Make this a long random string (e.g. openssl rand -hex 20)
CALENDAR_TOKEN=your-random-secret-here

# ── Google Calendar (family events auto-sync) ─────────────────
# 1. Go to console.cloud.google.com → IAM & Admin → Service Accounts → Create
# 2. Enable the Google Calendar API for your project
# 3. Download the JSON key for the service account
# 4. Share your calendar with the service account email (grant "Make changes to events")
# 5. In Vercel env vars, paste the private_key value with literal \n (not real newlines)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMII...\n-----END RSA PRIVATE KEY-----\n"
