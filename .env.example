# ── Supabase ──────────────────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Google Maps ──────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New) and Maps JavaScript API
# Restrict key to your domain for security
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key

# ── Anthropic (for AI features) ─────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Resend (for email delivery) ──────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=your-resend-api-key

# ── Cron security ────────────────────────────────────────────
# Set a random secret to protect the /api/send-nudge endpoint
CRON_SECRET=your-random-secret-here
